{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],

    "declaration": true,
    "emitDeclarationOnly": true,

    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "skipLibCheck": true,

    "experimentalDecorators": true,
    "useDefineForClassFields": false,   
  },
  "include": ["src"]
}