<%- include('base-top') %>
<div class="form-wrapper">
  <h2>Edit product</h2>
  <form action="/api/product/edit" method="POST">
    <input type="hidden" name="productId" value="<%= product._id %>" />
    <input
      type="text"
      name="name"
      id="name"
      placeholder="name"
      value="<%= product.name %>"
    />
    <input
      type="text"
      name="price"
      id="price"
      placeholder="price"
      value="<%= product.price %>"
    />
    <input
      type="text"
      name="description"
      id="description"
      placeholder="description"
      value="<%= product.description %>"
    />
    <input
      type="text"
      name="inventory"
      id="inventory"
      placeholder="inventory"
      value="<%= product.inventory %>"
    />
    <button type="submit">Update Product</button>
    <!-- Include the CSRF token as a hidden input -->
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  </form>
  <form action="/api/product/delete" method="POST">
    <input type="hidden" name="productId" value="<%= product._id %>" />
    <button type="submit">Delete Product</button>
    <!-- Include the CSRF token as a hidden input -->
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  </form>
</div>
<%- include('base-bottom') %>
