<%- include('base-top') %>
<div class="form-wrapper">
  <h2>Add product</h2>
  <form action="/api/product" method="POST">
    <label for="name">Name:</label>
    <% const nameError = validationErrors.find(e => e.path === 'name'); %>
    <input type="text" name="name" id="name" placeholder="name" value="<%= previousValues?.name %>" class="<%= nameError ? 'invalid' : '' %>" />
    <% if (nameError) { %>
      <p class="invalid"><%= nameError.msg %></p>
    <% } %>
    
    <label for="price">Price:</label>
    <% const priceError = validationErrors.find(e => e.path === 'price'); %>
    <input type="text" name="price" id="price" placeholder="price" value="<%= previousValues?.price %>" class="<%= priceError ? 'invalid' : '' %>" />
    <% if (priceError) { %>
      <p class="invalid"><%= priceError.msg %></p>
    <% } %>

    <label for="description">Description:</label>
    <% const descriptionError = validationErrors.find(e => e.path === 'description'); %>
    <input type="text" name="description" id="description" placeholder="description" value="<%= previousValues?.description %>" class="<%= descriptionError ? 'invalid' : '' %>" />
    <% if (descriptionError) { %>
      <p class="invalid"><%= descriptionError.msg %></p>
    <% } %>

    <label for="inventory">Inventory:</label>
    <% const inventoryError = validationErrors.find(e => e.path === 'inventory'); %>
    <input type="text" name="inventory" id="inventory" placeholder="inventory" value="<%= previousValues?.inventory %>" class="<%= inventoryError ? 'invalid' : '' %>" />
    <% if (inventoryError) { %>
      <p class="invalid"><%= inventoryError.msg %></p>
    <% } %>

    <button type="submit">Add Product</button>
    <!-- Include the CSRF token as a hidden input -->
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  </form>
</div>
<%- include('base-bottom') %>