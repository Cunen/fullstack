<%- include('base-top') %>
<div class="product-list">
  <h2>Shopping cart</h2>
  <% if (products && products.length > 0) { %>
    <% products.forEach(product => { %>
      <div class="product-item">
        <div class="info">
          <p>Product: <%= product.name %></p>
          <p><%= product.price %>€</p>
          <% if (product.description) { %>
            <p>Description: <%= product.description %></p>
          <% } %>
        </div>
        <div class="total">Total: <%= product.price * product.count %>€</div>
      </div>
      <form action="/api/cart/edit" method="POST">
        <input type="hidden" name="id" value="<%= product.id %>" />
        <input type="number" name="count" id="count" value="<%= product.count %>" min="1" max="<%= product.inventory %>" />
        <button type="submit">Update Count</button>
      </form>

      <form action="/api/cart/remove" method="POST">
        <input type="hidden" name="id" value="<%= product.id %>" />
        <button type="submit">Delete</button>
      </form>
    <% }); %>
  <% } %>
</div>
<a href="/view/checkout"><button>Go to checkout</button></a>
<%- include('base-bottom') %>