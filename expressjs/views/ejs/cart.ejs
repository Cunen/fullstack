<%- include('base-top') %>
<div class="product-list">
  <h2>Shopping cart</h2>
  <% if (items && items.length > 0) { %>
    <% items.forEach(item => { %>
      <div class="product-item">
        <div class="info">
          <p>Product: <%= item.product.name %></p>
          <p><%= item.product.price %>€</p>
          <% if (item.product.description) { %>
            <p>Description: <%= item.product.description %></p>
          <% } %>
        </div>
        <div class="total">Total: <%= item.product.price * item.count %>€</div>
      </div>
      <form action="/api/cart/edit" method="POST">
        <input type="hidden" name="id" value="<%= item._id %>" />
        <input type="number" name="count" id="count" value="<%= item.count %>" min="1" max="<%= item.product.inventory %>" />
        <button type="submit">Update Count</button>
      </form>

      <form action="/api/cart/remove" method="POST">
        <input type="hidden" name="id" value="<%= item._id %>" />
        <button type="submit">Delete</button>
      </form>
    <% }); %>
  <% } %>
</div>
<a href="/view/checkout"><button>Go to checkout</button></a>
<%- include('base-bottom') %>