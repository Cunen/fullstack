<%- include('base-top') %>
<div class="product-list">
  <h2>Products</h2>
  <% if (products && products.length > 0) { %>
    <% products.forEach(product => { %>
      <div class="product-item">
        <div class="counter">
          <p class="<% if (product.inventory === 0) { %>out<% } %>"><%= product.inventory %></p>
        </div>
        <div class="info">
          <p>Product: <%= product.name %></p>
          <p><%= product.price %>€</p>
          <% if (product.description) { %>
            <p>Description: <%= product.description %></p>
          <% } %>
          <a href="/view/product/<%= product.id %>">View Product</a>
        </div>
      </div>
    <% }); %>
  <% } %>
</div>
<%- include('base-bottom') %>